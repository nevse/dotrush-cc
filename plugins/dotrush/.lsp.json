{
  "csharp": {
    "command": "${CLAUDE_PLUGIN_ROOT}/bin/lsp-proxy.py",
    "transport": "stdio",
    "extensionToLanguage": {
      ".cs": "csharp",
      ".csx": "csharp",
      ".cshtml": "csharp"
    },
    "env": {
      "DOTRUSH_SERVER_DIR": "${CLAUDE_PLUGIN_DATA}/server",
      "DOTRUSH_INSTALL_SCRIPT": "${CLAUDE_PLUGIN_ROOT}/scripts/install-dotrush.sh",
      "DOTRUSH_DATA_DIR": "${CLAUDE_PLUGIN_DATA}",
      "DOTRUSH_WORKSPACE": "${CLAUDE_PROJECT_DIR}"
    },
    "initializationOptions": {},
    "settings": {},
    "startupTimeout": 180000,
    "restartOnCrash": true,
    "maxRestarts": 2
  }
}
